{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Work Reporter",
  "version": "1.0.0",
  "identifier": "com.workreport.archive",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:frontend"
  },
  "app": {
    "windows": [
      {
        "title": "Work Reporter",
        "width": 1100,
        "height": 750,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJDMzY1NUEyMTEzREI5OEUKUldTT3VUMFJvbFUydkY0NlJ0STl4SFlzMTc4bjNWeDhFRlQ4OWJLM3hlZG1JQklVTCtYalg2M1QK",
      "endpoints": [
        "https://github.com/w34538y/work-report/releases/latest/download/latest.json"
      ]
    }
  }
}
